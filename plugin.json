{
  "spec": "soksak-plugin-spec@1",
  "id": "soksak-plugin-shark",
  "name": { "en": "shork shark", "ko": "shork shark" },
  "version": "1.0.2",
  "repo": "https://github.com/soksak-ai/soksak-plugin-shark.git",
  "description": { "en": "A shork shark lazily swimming across the app — the SOKSAK wordmark is the shark itself (S=head, K=tail). Shark count and liveliness are adjustable.", "ko": "앱 위를 유유자적 헤엄쳐 다니는 shork shark — SOKSAK 워드마크가 곧 상어(S=머리, K=꼬리). 마릿수·활기 조절." },
  "entry": "main.js",
  "permissions": ["ui:overlay:screen", "commands"],
  "contributes": {
    "commands": [
      { "name": "toggle", "title": { "en": "Toggle shork", "ko": "shork 켜기/끄기" } },
      { "name": "mode", "title": { "en": "Interaction mode", "ko": "인터랙션 모드" } },
      { "name": "speed", "title": { "en": "Liveliness", "ko": "활기 설정" } },
      { "name": "count", "title": { "en": "Shark count", "ko": "상어 수" } }
    ]
  }
}
