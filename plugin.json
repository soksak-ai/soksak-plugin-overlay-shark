{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-overlay-shark",
  "name": {
    "en": "shork shark",
    "ko": "shork shark"
  },
  "version": "0.0.1",
  "description": {
    "en": "A shork shark lazily swimming across the app \u2014 the SOKSAK wordmark is the shark itself (S=head, K=tail). Shark count and liveliness are adjustable.",
    "ko": "\uc571 \uc704\ub97c \uc720\uc720\uc790\uc801 \ud5e4\uc5c4\uccd0 \ub2e4\ub2c8\ub294 shork shark \u2014 SOKSAK \uc6cc\ub4dc\ub9c8\ud06c\uac00 \uace7 \uc0c1\uc5b4(S=\uba38\ub9ac, K=\uaf2c\ub9ac). \ub9c8\ub9bf\uc218\u00b7\ud65c\uae30 \uc870\uc808."
  },
  "entry": "main.js",
  "permissions": [
    "ui:overlay:screen",
    "commands"
  ],
  "contributes": {
    "commands": [
      {
        "name": "toggle",
        "title": {
          "en": "Toggle shork",
          "ko": "shork \ucf1c\uae30/\ub044\uae30"
        }
      },
      {
        "name": "mode",
        "title": {
          "en": "Interaction mode",
          "ko": "\uc778\ud130\ub799\uc158 \ubaa8\ub4dc"
        }
      },
      {
        "name": "speed",
        "title": {
          "en": "Liveliness",
          "ko": "\ud65c\uae30 \uc124\uc815"
        }
      },
      {
        "name": "count",
        "title": {
          "en": "Shark count",
          "ko": "\uc0c1\uc5b4 \uc218"
        }
      }
    ]
  }
}
